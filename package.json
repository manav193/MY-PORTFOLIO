{
  "name": "portfolio",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "node scripts/production-build.mjs",
    "build:root": "node scripts/production-build.mjs --base /",
    "build:subdir": "node scripts/production-build.mjs --base /portfolio/",
    "preview": "npx vite preview --port 4173",
    "verify": "playwright test tests/global-shell-regression.spec.js",
    "test:arcade": "playwright test tests/arcade-regression.spec.js",
    "test:experience": "playwright test tests/experience-audio.spec.js",
    "test:developer": "playwright test tests/developer-mode.spec.js",
    "test:production": "playwright test tests/final-production-qa.spec.js --config=playwright.production.config.js"
  },
  "dependencies": {
    "clean-css": "^5.3.3",
    "esbuild": "^0.28.1",
    "html-minifier-terser": "^7.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
