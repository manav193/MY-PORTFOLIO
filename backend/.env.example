# NIMO Backend Service Environment Variables
# Copy to .env for local development — NEVER commit .env with real secrets to version control.

PORT=3000

# OpenRouter API Key and Default AI Model
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Allowed Origins for CORS Security (comma separated)
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5500,http://127.0.0.1:5500,http://localhost:4173,https://my-portfolio-mu-jade-52.vercel.app
